build/
.astro/

# Dependencies
node_modules/
.pnpm-store/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Temporary folders
tmp/
temp/

# Cache directories
.cache/
.parcel-cache/

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Linux
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Nix
result
result-*

# Docker
.dockerignore

# Backup files
*.bak
*.backup
*.old

# Test artifacts
test-results/
coverage/

# Local configuration files
config.local.*
*.local

# Runtime files
*.pid
*.lock

# Temporary files
*.tmp
*.temp

# Archive files (unless specifically needed)
*.tar
*.tar.gz
*.zip
*.rar

# IDE and editor files
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# Vim
*.swp
*.swo
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# User-specific files
.user.ini
.personal/

# Local development files
.local/
local/

# Generated documentation (if auto-generated)
docs/generated/

# Incus/LXD specific (if any local state files are created)
*.state
*.backup

# Shell history and local configs
.bash_history
.zsh_history
.fish_history

# GPG
secring.*

# SSH
.ssh/

# Any local scripts or configs that shouldn't be shared
local.*
*.local.*